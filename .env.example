# ci-cd-demo environment template
# 当前最小 Demo 阶段不需要真实密钥。
# 本文件主要用于提前约定后续 CI/CD 与部署变量命名。

# Image registry
REGISTRY=ghcr.io
IMAGE_NAMESPACE=your-org-or-user
BACKEND_IMAGE=ci-cd-demo-backend
FRONTEND_IMAGE=ci-cd-demo-frontend

# Deployment target
SERVER_HOST=your-server-host
SERVER_USER=your-server-user
SERVER_PORT=22
DEPLOY_PATH=/opt/ci-cd-demo
